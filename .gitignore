# Environments
.venv/
venv/
ENV/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Databases — the master AND every tenant school's own file. Real school data
# must never be committed. (seed_all_tenants writes copies into backups/.)
*.sqlite3
db.sqlite3
backups/

# Per-install secrets — MUST NEVER be committed. Each install generates its own;
# back these up alongside the database (losing them logs users out / needs
# gateway+SMS secrets re-entered, but nothing else breaks).
.secret_key
.field_key
.vapid_key
.env

# Media and Static folders
staticfiles/
media/

# Build & Compilation
build/
dist/
*.spec

# IDEs
.vscode/
.idea/
.gemini/
.claude/
